<!DOCTYPE html>
<html>
<head>
  <title>Edit Data</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<h2>Edit Data</h2>

<form action="/edit/<%= index %>" method="POST">
  <input type="text" name="name" value="<%= user.name %>" required>
  <input type="number" name="height" value="<%= user.height %>" required>
  <input type="number" step="0.01" name="weight" value="<%= user.weight %>" required>
  <input type="date" name="birthdate" value="<%= user.birthdate %>" required>

  <select name="married">
    <option value="true" <%= user.married ? "selected" : "" %>>True</option>
    <option value="false" <%= !user.married ? "selected" : "" %>>False</option>
  </select>

  <button type="submit">Update</button>
</form>

<a href="/">Back</a>

</body>
</html>